# /home/obsidian/.config/obsidian-sync/env
# Copy to the path above and fill in real values.
# Permissions: chmod 600 /home/obsidian/.config/obsidian-sync/env

# --- Git Sync heartbeat (Uptime Kuma push URL) ---
# Create a "Push" monitor in Uptime Kuma named "(Obsidian) Git Sync"
# Format: http://${MONITOR_HOST}:3001/api/push/<push_token>?status=up&msg=OK&ping=
VAULT_MCP_HEARTBEAT_URL=<replace-with-push-url>

# --- Headless Sync heartbeat (Uptime Kuma push URL) ---
# Create a "Push" monitor in Uptime Kuma named "(Obsidian) Headless Sync"
OBSIDIAN_HEADLESS_HEARTBEAT_URL=<replace-with-push-url>
