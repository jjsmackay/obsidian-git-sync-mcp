# /home/bobsidian/.config/obsidian-sync/env
# Copy to the path above and fill in real values.
# Permissions: chmod 600 /home/bobsidian/.config/obsidian-sync/env

# --- Git Sync heartbeat (Uptime Kuma push URL) ---
# Create a "Push" monitor in Uptime Kuma named "Obsidian Git Sync"
# Use the *internal* Kuma hostname — the public one is behind Cloudflare Access
# and will return a login redirect instead of hitting the push endpoint.
# Wrap the URL in double quotes — the `&` separators break `source` otherwise.
# Format: "http://${MONITOR_HOST}:3001/api/push/<push_token>?status=up&msg=OK&ping="
GIT_SYNC_HEARTBEAT_URL="<replace-with-push-url>"

# --- Headless Sync heartbeat (Uptime Kuma push URL) ---
# Create a "Push" monitor in Uptime Kuma named "Obsidian Headless Sync"
# Same rules: internal hostname, quoted.
OBSIDIAN_SYNC_HEARTBEAT_URL="<replace-with-push-url>"
