# /home/bobsidian/.config/obsidian-mcp/env
# Copy to the path above and fill in real values.
# Permissions: chmod 600 /home/bobsidian/.config/obsidian-mcp/env

# --- Vault ---
VAULT_PATH="/home/bobsidian/obsidian-vault/"

# --- Server ---
VAULT_MCP_PORT=8420

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
VAULT_MCP_TOKEN=<replace-with-random-hex-token>

# --- OAuth 2.0 (Claude custom connector) ---
VAULT_OAUTH_CLIENT_ID=bobsidian
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
VAULT_OAUTH_CLIENT_SECRET=<replace-with-random-hex-token>

# --- DNS rebinding protection ---
VAULT_MCP_ALLOWED_HOSTS=${PUBLIC_HOST}

# --- Public base URL (behind Cloudflare Tunnel) ---
# Forces OAuth metadata endpoints to advertise this URL instead of deriving
# it from request headers. Set this to the tunnel hostname so Claude sees
# https URLs in discovery.
VAULT_PUBLIC_BASE_URL=https://${PUBLIC_HOST}

# --- Streamable-HTTP transport (defaults shown) ---
# Stateless mode — each POST is independent, avoids session-id round-tripping
# that breaks through some proxies. Claude's remote connector requires this.
VAULT_MCP_STATELESS=true
# Path the server mounts MCP at. Must match what the client POSTs.
VAULT_MCP_PATH=/mcp

# --- MCP server heartbeat (optional) ---
# If set, the server sends a GET to this URL every VAULT_MCP_HEARTBEAT_INTERVAL
# seconds (default 60). Leave URL unset to disable.
#
# Create a Push-type monitor in Uptime Kuma named "(Obsidian) MCP" (interval
# 120s, retries 3). Paste its push URL below.
#
# Use the *internal* Kuma hostname — the public one is behind Cloudflare Access
# and will bounce the push with a login redirect.
# Wrap the URL in double quotes — the `&` separators break `source` otherwise.
# VAULT_MCP_HEARTBEAT_URL="http://${MONITOR_HOST}:3001/api/push/<push_token>?status=up&msg=OK&ping="
# VAULT_MCP_HEARTBEAT_INTERVAL=60

# --- Post-write hook (git sync) ---
VAULT_MCP_POST_WRITE_CMD=/home/bobsidian/obsidian-sync/scripts/git-sync.sh
