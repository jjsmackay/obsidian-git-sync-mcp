# /home/obsidian/.config/obsidian-mcp/env
# Copy to the path above and fill in real values.
# Permissions: chmod 600 /home/obsidian/.config/obsidian-mcp/env

# --- Vault ---
VAULT_PATH="/home/obsidian/Vaults/a self-hosted homelab (Sync)/"

# --- Server ---
VAULT_MCP_PORT=8420

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
VAULT_MCP_TOKEN=<replace-with-random-hex-token>

# --- OAuth 2.0 (Claude custom connector) ---
VAULT_OAUTH_CLIENT_ID=bobsidian
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
VAULT_OAUTH_CLIENT_SECRET=<replace-with-random-hex-token>

# --- DNS rebinding protection ---
VAULT_MCP_ALLOWED_HOSTS=${PUBLIC_HOST}

# --- Post-write hook (git sync) ---
VAULT_MCP_POST_WRITE_CMD=/home/obsidian/obsidian-sync/scripts/obsidian-git-sync.sh
