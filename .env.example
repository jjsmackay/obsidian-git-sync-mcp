# Configuration for the git-sync MCP deployment.
#
# Copy to .env and edit. Copying as-is is a safe, bootable no-op: the git-sync
# extension stays DISABLED (see VAULT_GIT_ENABLED below) until you turn it on.
#
#   cp .env.example .env && docker compose up -d
#
# .env is gitignored -- never commit real tokens, passwords, or vault paths.

# =============================================================================
# Upstream obsidian-web-mcp server (VAULT_*)
# =============================================================================

# Path INSIDE the container where the vault git working tree is mounted. The
# compose volume maps VAULT_HOST_PATH on the host to this path. Must be a git
# working tree for git-sync to commit against.
VAULT_PATH=/vault

# Host path mounted to VAULT_PATH in docker-compose.yml (compose-only var).
VAULT_HOST_PATH=./vault

# Bearer token MCP clients must present. Required -- set a strong random value.
VAULT_MCP_TOKEN=

# Port the MCP transport listens on (and the port compose publishes).
VAULT_MCP_PORT=8420

# Network bind address. Upstream defaults to loopback (127.0.0.1); inside a
# container it MUST bind all interfaces to be reachable on the published port.
# Keep it behind a reverse proxy / tunnel for remote access -- do not expose the
# published port directly to the internet.
VAULT_MCP_HOST=0.0.0.0

# Extra hostnames allowed through DNS-rebinding protection, comma-separated.
# Loopback is always allowed; add your public proxy/tunnel hostname here,
# e.g. vault-mcp.example.com.
VAULT_MCP_ALLOWED_HOSTS=

# Canonical public origin the server advertises in OAuth discovery + auth
# challenges, e.g. https://vault-mcp.example.com. Pins those URLs against Host
# spoofing. Empty = derive from each request.
VAULT_MCP_PUBLIC_URL=

# --- OAuth (for the Claude app browser integration; optional) ----------------
# Static operator client id.
VAULT_OAUTH_CLIENT_ID=vault-mcp-client
# Static operator client secret (set for the client_credentials grant).
VAULT_OAUTH_CLIENT_SECRET=
# Interactive login gate on /oauth/authorize -- authenticates the human before
# any token is issued.
VAULT_OAUTH_USERNAME=obsidian
VAULT_OAUTH_PASSWORD=
# Allowed redirect URIs for the operator client, comma-separated.
VAULT_OAUTH_REDIRECT_URIS=

# =============================================================================
# Git-sync extension (VAULT_GIT_*)
# =============================================================================
# DISABLED by default. Leave VAULT_GIT_ENABLED empty for a no-op boot; set it
# truthy to turn the extension on, then review the rest of this section.

# Master switch. "true"/"1"/"yes"/"on" enables; empty/anything else disables.
VAULT_GIT_ENABLED=

# Seconds between periodic full-tree sweeps (catches attachments/canvas the .md
# watcher misses). Positive integer; default 60.
VAULT_GIT_SWEEP_INTERVAL=60

# Remote to push to. "origin" (default) pushes; "" = commit-only (local backup,
# never pushes).
VAULT_GIT_REMOTE=origin

# Branch to push. Empty = use the working tree's current branch.
VAULT_GIT_BRANCH=

# Seconds the event queue must be quiet before the worker pushes batched commits.
# Positive number; default 10.
VAULT_GIT_PUSH_DEBOUNCE=10

# Upper bound (seconds) on time-since-last-push so sustained activity still
# pushes periodically. Positive number; default 300.
VAULT_GIT_PUSH_MAX_INTERVAL=300

# Commit author identity. Empty = fall back to git's configured identity (a
# user.name/user.email in the vault's git config). A resolvable identity is
# REQUIRED: with neither these vars nor a configured git identity, git refuses to
# commit and every sweep fails with rc=128 (nothing committed or pushed). Set both
# here for a self-contained deployment.
VAULT_GIT_GIT_AUTHOR_NAME=
VAULT_GIT_GIT_AUTHOR_EMAIL=

# Frontmatter timestamp stamping. Defaults ON (empty = on); set a falsey value
# ("0"/"false"/"no"/"off") to commit MCP-written files unstamped.
VAULT_GIT_STAMP=

# Optional push heartbeat. When set to an http(s) URL, the worker pings it after
# each successful push (push-style monitors: Uptime Kuma, Healthchecks.io, …).
# Empty = disabled. Fires only on push success, never in commit-only mode.
VAULT_GIT_HEARTBEAT_URL=
